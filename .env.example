# ─────────────────────────────────────────────
# LOCAL DEV (server.js — not used in production)
# ─────────────────────────────────────────────
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_smtp_password
RECIPIENT_EMAIL=you@yourdomain.com
PORT=3000

# ─────────────────────────────────────────────
# SUPABASE EDGE FUNCTION SECRETS
# Set these via: supabase secrets set KEY=value
# ─────────────────────────────────────────────

# From Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# From resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key

# The email address that receives form submissions
RECIPIENT_EMAIL=you@yourdomain.com

# The "from" address for outgoing emails (must be a verified domain in Resend)
SENDER_EMAIL=noreply@yourdomain.com
